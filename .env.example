# ─── Servidor (bootstrap — não coloque APIs/keys aqui) ───────────────────────
API_PORT=3000
ADMIN_SECRET=altere-este-segredo-admin
DATABASE_URL=postgresql://aguia:aguia@postgres:5432/aguia
JWT_SECRET=altere-este-jwt-secret-forte
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_DAYS=7
JWT_SESSION_REFRESH_DAYS=1
JWT_REMEMBER_REFRESH_DAYS=90
RESET_CODE_EXPIRES_MIN=10
RESET_MAX_REQUESTS=3
RATE_LIMIT_AUTH_LOGIN=10
RATE_LIMIT_VEHICLE_COMMANDS=8
CORS_ORIGIN=http://localhost:8080
REDIS_URL=redis://localhost:6379
# Multi-tenant SaaS (Fase 1) — false mantém single-tenant Águia
MULTI_TENANT_ENABLED=false
# Frontend: espelha MULTI_TENANT_ENABLED para menu dinâmico e branding
VITE_MULTI_TENANT_ENABLED=false
# Slug padrão quando não há subdomínio (ex.: localhost)
VITE_TENANT_SLUG=aguia
# Swagger UI em /v1/docs — false desabilita em produção
OPENAPI_DOCS_ENABLED=true

# Firebase, WhatsApp, GPSWOX, Asaas, SMS → configure pelo painel admin em /admin
# Gateways SMS (rastreador): /admin/sms — credenciais ficam no banco, não aqui
# Sync avançado templates GPSWOX (get_user_sms_templates) — oculto por padrão no admin:
# VITE_SHOW_GPSWOX_SMS_TEMPLATES=true
# Gateway SMS GPSWOX (entrada HTTP): Integrações ou variáveis abaixo (opcional)
# SMS_GPSWOX_GATEWAY_USER=
# SMS_GPSWOX_GATEWAY_PASSWORD=
# SMS_GPSWOX_GATEWAY_PUBLIC_URL=https://api.seudominio.com
# Sync automático veículos GPSWOX (poll a cada 15min, executa conforme intervalo)
# GPSWOX_AUTO_SYNC_ENABLED=true
# GPSWOX_AUTO_SYNC_INTERVAL_HOURS=24
# GPSWOX_SYNC_CHECK_MS=900000
# BILLING_REMINDER_CHECK_MS=3600000
