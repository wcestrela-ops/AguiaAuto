# ─── Servidor (bootstrap — não coloque APIs/keys aqui) ───────────────────────
API_PORT=3000
ADMIN_SECRET=altere-este-segredo-admin
DATABASE_URL=postgresql://aguia:aguia@postgres:5432/aguia
JWT_SECRET=altere-este-jwt-secret

# ─── Fallback opcional (usado só até configurar no painel admin) ─────────────
# Após configurar via PUT /v1/admin/integracoes/:key, o banco é a fonte da verdade.
GPSWOX_URL=https://seu-dominio.gpswox.com
GPSWOX_USER=admin@empresa.com
GPSWOX_PASS=senha-admin
GPSWOX_API_HASH=
GATEWAY_SECRET=altere-este-segredo-gateway
GATEWAY_URL=http://gpswox-gateway:3001
GATEWAY_PORT=3001
HEADLESS=true
NAV_TIMEOUT=30000
