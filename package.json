{
  "name": "aguia-gestao-veicular",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma SaaS Águia Gestão Veicular",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @aguia/api",
    "dev:gateway": "npm run dev -w @aguia/gpswox-gateway",
    "dev:web": "npm run dev -w @aguia/web",
    "start:api": "npm run start -w @aguia/api",
    "start:worker": "npm run start:worker -w @aguia/api",
    "start:scheduler": "npm run start:scheduler -w @aguia/api",
    "start:gateway": "npm run start -w @aguia/gpswox-gateway",
    "build:web": "npm run build -w @aguia/web",
    "test": "npm run test -w @aguia/api && npm run test -w @aguia/web && npm run test -w @aguia/gpswox-gateway",
    "test:api": "npm run test -w @aguia/api",
    "test:web": "npm run test -w @aguia/web",
    "test:gateway": "npm run test -w @aguia/gpswox-gateway",
    "load-test": "node scripts/load-test.js",
    "load-test:k6": "k6 run scripts/k6/auth-smoke.js",
    "diagnostico": "npm run diagnostico -w @aguia/gpswox-gateway"
  }
}
