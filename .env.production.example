# Copie para .env antes do deploy no EasyPanel
# cp .env.production.example .env

# ─── Banco ───────────────────────────────────────────────────────────────────
POSTGRES_USER=aguia
POSTGRES_PASSWORD=troque-por-senha-forte-do-banco
POSTGRES_DB=aguia
DATABASE_URL=postgresql://aguia:troque-por-senha-forte-do-banco@postgres:5432/aguia

# ─── Segurança ─────────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-segredo-jwt-forte-min-32-chars

# ─── Segurança Fase 3 ─────────────────────────────────────────────────────────
ENCRYPTION_KEY=troque-por-chave-forte-min-32-chars
SESSION_SECRET=troque-por-session-secret-forte
TOTP_ISSUER=AguiaAuto
JWT_ACCESS_EXPIRES_IN=1h
JWT_ADMIN_REFRESH_DAYS=1
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_TIME=15
PASSWORD_MIN_LENGTH=10
ADMIN_BOOTSTRAP_EMAIL=admin@suaempresa.com.br
ADMIN_BOOTSTRAP_PASSWORD=troque-por-senha-admin-forte-min-10-chars
# ADMIN_SECRET= — legado, descontinuar após migração

# ─── Domínio público (com https, sem barra no final) ───────────────────────────
CORS_ORIGIN=https://app.suaempresa.com.br

# ─── Gateway interno (mesmo valor em Admin → Integrações → Gateway GPSWOX) ───
GATEWAY_URL=http://gpswox-gateway:3001
GATEWAY_SECRET=troque-por-segredo-compartilhado-api-gateway

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000
PROCESS_ROLE=api

# ─── Sessão cliente (opcional) ───────────────────────────────────────────────
JWT_ACCESS_EXPIRES=1h
JWT_SESSION_REFRESH_DAYS=1
JWT_REMEMBER_REFRESH_DAYS=90

# ─── Redis (cache, filas BullMQ, rate limit, presença) ────────────────────────
REDIS_URL=redis://redis:6379

# ─── Multi-tenant SaaS (Fases 1–8) ───────────────────────────────────────────
# false (default) — single-tenant Águia; true — isolamento por tenant + módulos
MULTI_TENANT_ENABLED=false

# ─── Worker / Scheduler ───────────────────────────────────────────────────────
# Em produção com docker-compose.prod.yml, worker e scheduler rodam em containers separados.
# ENABLE_INLINE_POLLERS=true força pollers na API (somente dev/legado).
# ENABLE_INLINE_POLLERS=false

# ─── Tracking cache / sync inteligente ─────────────────────────────────────────
TRACKING_CACHE_TTL_SECONDS=86400
TRACKING_CACHE_STALE_MS=60000
TRACKING_POLL_LIVE_MS=8000
TRACKING_POLL_ONLINE_MS=45000
TRACKING_POLL_OFFLINE_MS=180000
TRACKING_SCHEDULER_MS=15000

# ─── Monitoramento (opcional) ──────────────────────────────────────────────────
# SENTRY_DSN=
# UPTIME_KUMA_PUSH_URL=
PROMETHEUS_ENABLED=false
# LOG_LEVEL=info

# Firebase, Asaas, GPSWOX, WhatsApp, SMTP → configure depois em /admin/integracoes
#
# ─── Deploy ───────────────────────────────────────────────────────────────────
# Guia: docs/deploy/easypanel.md
# Pré-check: ./scripts/deploy-check.sh .env
# Runbook: docs/operations/runbook.md
