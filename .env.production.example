# Copie para .env antes do deploy no EasyPanel
# cp .env.production.example .env

# ─── Banco ───────────────────────────────────────────────────────────────────
POSTGRES_USER=aguia
POSTGRES_PASSWORD=troque-por-senha-forte-do-banco
POSTGRES_DB=aguia
DATABASE_URL=postgresql://aguia:troque-por-senha-forte-do-banco@postgres:5432/aguia

# ─── Segurança ─────────────────────────────────────────────────────────────────
ADMIN_SECRET=troque-por-segredo-admin-forte-min-32-chars
JWT_SECRET=troque-por-segredo-jwt-forte-min-32-chars

# ─── Domínio público (com https, sem barra no final) ───────────────────────────
CORS_ORIGIN=https://app.suaempresa.com.br

# ─── Gateway interno (mesmo valor em Admin → Integrações → Gateway GPSWOX) ───
GATEWAY_URL=http://gpswox-gateway:3001
GATEWAY_SECRET=troque-por-segredo-compartilhado-api-gateway

# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000

# ─── Sessão cliente (opcional) ───────────────────────────────────────────────
JWT_ACCESS_EXPIRES=1h
JWT_SESSION_REFRESH_DAYS=1
JWT_REMEMBER_REFRESH_DAYS=90

# Firebase, Asaas, GPSWOX, WhatsApp, SMTP → configure depois em /admin/integracoes
