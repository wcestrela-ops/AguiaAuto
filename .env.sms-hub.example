# AG SMS Hub — copie para .env.sms-hub e ajuste em produção
# cp .env.sms-hub.example .env.sms-hub

# ─── API ─────────────────────────────────────────────────────────────────────
SMS_HUB_API_PORT=4000
SMS_HUB_DATABASE_URL=postgresql://ag_smshub:ag_smshub@localhost:5433/ag_smshub
SMS_HUB_REDIS_URL=redis://localhost:6380
SMS_HUB_JWT_SECRET=altere-este-jwt-secret-forte-ag-smshub
SMS_HUB_JWT_ACCESS_EXPIRES=1h
SMS_HUB_JWT_REFRESH_DAYS=7
SMS_HUB_CORS_ORIGIN=http://localhost:5174,http://localhost:5173,http://localhost:8080
NODE_ENV=development

# Bridge — mesmo valor do ADMIN_SECRET da Águia (login admin unificado)
AGUIA_ADMIN_SECRET=altere-este-segredo-admin
AGUIA_SERVICE_SECRET=altere-este-segredo-admin

# ─── Seed (desenvolvimento) ──────────────────────────────────────────────────
SMS_HUB_ADMIN_EMAIL=admin@agsmshub.local
SMS_HUB_ADMIN_PASSWORD=admin123456
SMS_HUB_OPERATOR_EMAIL=operador@empresa.local
SMS_HUB_OPERATOR_PASSWORD=operador123456

# ─── Frontend (Vite — opcional em dev local) ─────────────────────────────────
VITE_API_URL=/api
